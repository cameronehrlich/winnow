GEMINI_API_KEY=your_gemini_key
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_APP_TOKEN=xapp-your-token
WINNOW_API_TOKEN=generate-a-long-random-token

# Optional APNs delivery for the private iOS app. Prefer APNS_PRIVATE_KEY_PATH;
# the .p8 key must stay outside the repository and be readable only by Winnow.
APNS_TEAM_ID=your-apple-developer-team-id
APNS_KEY_ID=your-apns-key-id
APNS_BUNDLE_ID=com.cameronehrlich.Winnow
APNS_PRIVATE_KEY_PATH=/absolute/private/path/AuthKey_KEYID.p8

# Optional absolute Node path for PM2 when shell PATH differs from the intended runtime.
# WINNOW_NODE_INTERPRETER=/Users/you/.nvm/versions/node/v24.18.0/bin/node
