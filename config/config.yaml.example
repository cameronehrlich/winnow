# Winnow configuration
accounts:
  - email: you@example.com
    channel: C0PERSONAL_EMAIL

  # Optional: route one Gmail account to a different Slack workspace/app.
  # Keep tokens in .env and reference their variable names here.
  - email: work@example.com
    slack:
      channel_id: C0WORK_EMAIL
      bot_token_env: WORK_SLACK_BOT_TOKEN
      app_token_env: WORK_SLACK_APP_TOKEN

# Gmail adapter: "gog" (default) or "google-workspace" (future)
adapter: gog

# Slack notifications
slack:
  # Set SLACK_BOT_TOKEN and SLACK_APP_TOKEN in .env (preferred) or put tokens here.
  # Account-level slack.bot_token_env/app_token_env overrides these for separate workspaces.
  bot_token: ""
  app_token: ""
  channel_id: "YOUR_CHANNEL_ID"
  # all = keep current Slack feed behavior; kept = only inbox-worthy emails; off = no Slack feed
  feed_mode: all

# Local API for the future iOS app
api:
  host: 127.0.0.1
  port: 3777

daemon:
  scan_interval_seconds: 30

reconcile:
  interval_seconds: 300

# AI model configuration (uses GEMINI_API_KEY env var)
model:
  name: gemini-2.5-flash

# Scan settings
scan:
  max_messages: 50
  search_query: "in:inbox is:unread newer_than:1d"
